---
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { locales, type Locale } from '~/i18n';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'Features',
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="Features"
    title="Generation & Evaluation"
    subtitle="실세계 시공간 데이터로부터 고품질 합성 데이터를 생성하고, 통계적·목적적으로 품질을 검증합니다."
  />

  <Note id="generation" title="01 — Generation (생성)" description="도메인 지식을 인지한 고품질 합성 시공간 데이터 생성" />

  <Features2
    columns={2}
    items={[
      {
        title: 'Knowledge Encoding',
        description: '시공간 데이터의 구조·역학 등 사전지식을 생성 모델에 명시적으로 인코딩합니다.',
        icon: 'tabler:brain',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/features/generation/knowledge-encoding/') },
      },
      {
        title: 'Relation Modeling',
        description: '다변량 시공간 데이터 간 상관관계·인과관계를 모델링해 데이터 추론을 가능하게 합니다.',
        icon: 'tabler:network',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/features/generation/relation-modeling/') },
      },
      {
        title: 'Data Assimilation',
        description: '데이터 섭동 기술로 생성 중 누적 오차를 수정해 합성 정확도를 향상합니다.',
        icon: 'tabler:adjustments',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/features/generation/data-assimilation/') },
      },
      {
        title: 'Objective Reinforcement',
        description: '도메인 요구사항에 맞는 보상함수를 적용해 목적 맞춤형 합성 데이터를 생성합니다.',
        icon: 'tabler:target-arrow',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/features/generation/objective-reinforced/') },
      },
    ]}
  />

  <Note id="evaluation" title="02 — Evaluation (평가)" description="생성 데이터의 품질을 통계적·목적적으로 정량 검증" />

  <Features2
    columns={2}
    items={[
      {
        title: 'Statistical Similarity',
        description: '합성 데이터와 실제 데이터의 분포 유사성 및 변량 간 상관관계를 정량적으로 평가합니다.',
        icon: 'tabler:chart-bar',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/features/evaluation/statistical-similarity/') },
      },
      {
        title: 'Objective Relevance',
        description: '목적 맞춤형 AI 모델 성능을 실데이터·합성데이터·혼합 구성별로 비교해 적합성을 평가합니다.',
        icon: 'tabler:check',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/features/evaluation/objective-relevance/') },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>
</Layout>
