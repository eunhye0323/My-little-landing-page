---
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { locales, type Locale } from '~/i18n';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'Use Cases',
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="Use Cases"
    title="Real-World Applications"
    subtitle="Discover how synthetic data accelerates research and protects privacy across diverse domains."
  />

  <Features2
    title="Explore Use Cases"
    subtitle="Synthetic data enabling breakthroughs in medical imaging research."
    columns={2}
    items={[
      {
        title: 'Brain Imaging — Virtual Brain',
        description: 'Simulate longitudinal brain imaging changes associated with neurodegenerative diseases and generate synthetic brain imaging data for disease classification and prediction model development.',
        icon: 'tabler:brain',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/use-cases/brain-imaging/') },
      },
      {
        title: 'Breast Cancer',
        description: 'Demonstrate breast MRI generation and breast shape prediction technologies for surgical simulation, supporting treatment planning and shared decision-making between clinicians and patients.',
        icon: 'tabler:stethoscope',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/use-cases/breast-cancer/') },
      },
    ]}
  />
</Layout>