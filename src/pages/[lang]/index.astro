---
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, locales, type Locale } from '~/i18n';
import { externalLinks } from '~/config/externalLinks';
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'SSTDV — Synthetic Spatio-Temporal Data Vault',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: t(lang, 'nav.docs'),
        href: externalLinks.docs,
        target: '_blank',
        icon: 'tabler:book',
      },
      { text: t(lang, 'common.learnMore'), href: '#features' },
    ]}
  >
    <Fragment slot="title">
      {t(lang, 'hero.title')}
    </Fragment>
    <Fragment slot="subtitle">
      <span set:html={t(lang, 'hero.subtitle')} />
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="Generation"
    title="생성"
    subtitle="실세계 시공간 데이터로부터 도메인 지식을 인지한 고품질 합성 데이터를 생성합니다."
    items={[
      {
        title: 'Knowledge Encoding',
        description: 'Explicitly encode prior knowledge — structure, dynamics, and domain constraints — into generative models for spatio-temporal data.',
        icon: 'tabler:brain',
      },
      {
        title: 'Relation Modeling',
        description: 'Model correlations, causality, and teleconnections among multivariate spatio-temporal data to enable data inference.',
        icon: 'tabler:network',
      },
      {
        title: 'Data Assimilation',
        description: 'Correct accumulated errors and missing data during generation through data perturbation techniques to improve synthesis accuracy.',
        icon: 'tabler:adjustments',
      },
      {
        title: 'Objective Reinforcement',
        description: 'Learn spatio-temporal data generation models using reward functions aligned with domain data requirements and objectives.',
        icon: 'tabler:target-arrow',
      },
    ]}
  />

  <Features2
    tagline="Evaluation"
    title="평가"
    subtitle="생성된 합성 데이터의 품질을 통계적 유사성과 목적 적합성으로 정량 평가합니다."
    columns={2}
    items={[
      {
        title: 'Statistical Similarity',
        description: 'Quantitatively evaluate distributional similarity between synthetic and real data, including inter-variable correlations.',
        icon: 'tabler:chart-bar',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/features/evaluation/statistical-similarity/') },
      },
      {
        title: 'Objective Relevance',
        description: 'Assess fitness-for-purpose by comparing AI model performance with real-only, synthetic-only, and mixed data configurations.',
        icon: 'tabler:check',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/features/evaluation/objective-relevance/') },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Features2
    tagline="Use Cases"
    title="실증"
    subtitle="의료영상 두 분야에서 목적 강화 합성 데이터의 유효성을 검증합니다."
    columns={2}
    items={[
      {
        title: 'Brain Imaging — Virtual Brain',
        description: 'Simulate longitudinal brain imaging changes associated with neurodegenerative diseases. Generate synthetic brain MRI data for disease classification and prediction model development using data from Dongguk University and ADNI.',
        icon: 'tabler:brain',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/use-cases/brain-imaging/') },
      },
      {
        title: 'Breast Cancer Surgical Simulation',
        description: 'Generate objective-reinforced synthetic breast MRI for surgical planning and patient-doctor shared decision-making. Trained on 1,483 pre/post-operative cases, conditioning on tumor location, resection region, and implant information.',
        icon: 'tabler:stethoscope',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/use-cases/breast-cancer/') },
      },
    ]}
  />

  <Features2
    tagline="Resources"
    title="Documentation & Outcomes"
    subtitle="Access project documentation, tutorials, software tools, and research outcomes."
    columns={3}
    items={[
      {
        title: 'Docs',
        description: 'Project overview, tutorials for Virtual Brain and Breast Cancer pipelines, and software references for BrainShapeToolKit, DiffAM, and VCM.',
        icon: 'tabler:book',
        callToAction: { text: 'Go to Docs', href: externalLinks.docs, target: '_blank' },
      },
      {
        title: 'Publications & Patents',
        description: 'Peer-reviewed papers, patent filings, open datasets, and application outcomes from the SSTDV project.',
        icon: 'tabler:file-text',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/publications/') },
      },
      {
        title: 'Research Team',
        description: 'Meet the participating institutions — KAIST CGV, KIOST, Dongguk University, KAIST CNI, and Beamworks — and their respective research roles.',
        icon: 'tabler:users',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/about/') },
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: t(lang, 'nav.docs'),
        href: externalLinks.docs,
        target: '_blank',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">SSTDV Project</Fragment>
    <Fragment slot="subtitle">
      Supported by IITP grant funded by the Korea government (MSIT)<br />
      No.00223446 — Development of object-oriented synthetic data generation and evaluation methods
    </Fragment>
  </CallToAction>
</Layout>
