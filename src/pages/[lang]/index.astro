---
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, locales, type Locale } from '~/i18n';
import { externalLinks } from '~/config/externalLinks';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'SSTDV — Synthetic Spatio-Temporal Data Vault',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="About"
    image={{
      src: '~/assets/images/Rep.png',
      alt: 'SSTDV Research Team',
    }}
  >
    <Fragment slot="title">
      SSTDV
    </Fragment>
    <Fragment slot="subtitle">
      We develop state-of-the-art methods for generating and evaluating synthetic spatio-temporal data to advance machine learning in healthcare, environmental science, and beyond.
    </Fragment>
  </Hero>

  <Stats
    title="Project Overview"
    stats={[
      { title: 'Publications', amount: '12' },
      { title: 'Datasets Generated', amount: '48' },
      { title: 'Research Institutions', amount: '6' },
      { title: 'Years Active', amount: '3' },
    ]}
  />

  <Features3
    title="Research Areas"
    subtitle="Our team focuses on advancing the state of synthetic spatio-temporal data generation and evaluation."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Synthetic Data Generation',
        description: 'Developing methods to generate synthetic spatio-temporal data that preserves statistical properties of real-world data.',
        icon: 'tabler:template',
      },
      {
        title: 'Evaluation Metrics',
        description: 'Researching quantitative metrics to assess the quality and utility of synthetic data for various downstream tasks.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Privacy Preservation',
        description: 'Applying differential privacy and federated learning techniques to ensure privacy-preserving synthetic data generation.',
        icon: 'tabler:lock',
      },
      {
        title: 'Cross-Domain Adaptation',
        description: 'Studying methods to transfer models trained on synthetic data to real-world domains effectively.',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'Temporal Modeling',
        description: 'Developing models that capture temporal dependencies and dynamics in spatio-temporal sequences.',
        icon: 'tabler:clock',
      },
      {
        title: 'Uncertainty Quantification',
        description: 'Providing reliable uncertainty estimates for synthetic data to support decision-making in critical applications.',
        icon: 'tabler:question-mark',
      },
    ]}
  />

  <Features3
    title="Collaborators"
    subtitle="We work with leading institutions to advance synthetic data research."
    columns={4}
    isAfterContent={true}
    items={[
      {
        title: 'Medical Imaging Partners',
        description: 'Collaborating on synthetic medical imaging data for improved diagnostic AI.',
        icon: 'tabler:heartbeat',
      },
      {
        title: 'Environmental Agencies',
        description: 'Working with agencies to generate synthetic environmental monitoring data.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Academic Institutions',
        description: 'Partnering with universities for foundational research in synthetic data.',
        icon: 'tabler:school',
      },
      {
        title: 'Industry Partners',
        description: 'Applying synthetic data solutions to real-world industry challenges.',
        icon: 'tabler:building',
      },
    ]}
  />

  <Steps2
    title="Our Mission"
    subtitle="We are committed to advancing AI capabilities through high-quality synthetic data while ensuring privacy and ethical practices."
    items={[
      {
        title: 'Advance AI through quality synthetic data',
        description: 'Developing state-of-the-art methods to generate synthetic data that improves machine learning model performance and efficiency.',
      },
      {
        title: 'Ensure privacy and ethical practices',
        description: 'Conducting research with rigorous privacy protections and ethical guidelines for synthetic data usage.',
      },
      {
        title: 'Accelerate scientific discovery',
        description: 'Providing synthetic data solutions that accelerate research in healthcare, environmental science, and beyond.',
      },
    ]}
  />

  <Steps2
    title="Key Milestones"
    subtitle="Our research has produced significant contributions to the field of synthetic spatio-temporal data."
    isReversed={true}
    items={[
      {
        title: 'Published 12 peer-reviewed papers',
        description: 'Produced influential research published in top-tier venues including Nature MI, ICML, AAAI, and ICLR.',
        icon: 'tabler:file-text',
      },
      {
        title: 'Generated 48 benchmark datasets',
        description: 'Created comprehensive benchmark datasets for evaluating synthetic data generation and evaluation methods.',
        icon: 'tabler:database',
      },
      {
        title: 'Presented at major conferences',
        description: 'Shared our findings at leading international conferences, advancing the state of the art in the field.',
        icon: 'tabler:presentation',
      },
    ]}
  />

  <Features2
    title="Get In Touch"
    tagline="Contact us"
    columns={2}
    items={[
      {
        title: 'Email contact',
        description: 'For research inquiries and collaboration opportunities.',
        icon: 'tabler:mail',
      },
      {
        title: 'GitHub Issues',
        description: 'For project-related bug reports and feature requests.',
        icon: 'tabler:brand-github',
      },
    ]}
  />

  <Features2
    tagline="Resources"
    title="Documentation & Outcomes"
    subtitle="프로젝트 문서, 튜토리얼, 소프트웨어 툴, 연구 성과를 확인하세요."
    columns={3}
    items={[
      {
        title: 'Docs',
        description: 'Virtual Brain·Breast Cancer 튜토리얼 및 BrainShapeToolKit, DiffAM, VCM 레퍼런스.',
        icon: 'tabler:book',
        callToAction: { text: 'Go to Docs', href: externalLinks.docs, target: '_blank' },
      },
      {
        title: 'Publications & Patents',
        description: '논문·특허·오픈 데이터셋 및 활용 성과.',
        icon: 'tabler:file-text',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/publications/') },
      },
      {
        title: 'Research',
        description: 'SSTDV의 합성 데이터 생성 및 평가 방법론 소개.',
        icon: 'tabler:flask',
        callToAction: { text: t(lang, 'common.learnMore'), href: getRelativeLocaleUrl(lang, '/features/') },
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: t(lang, 'nav.docs'),
        href: externalLinks.docs,
        target: '_blank',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">SSTDV Project</Fragment>
    <Fragment slot="subtitle">
      Supported by IITP grant funded by the Korea government (MSIT)<br />
      No.00223446 — Development of object-oriented synthetic data generation and evaluation methods
    </Fragment>
  </CallToAction>
</Layout>
